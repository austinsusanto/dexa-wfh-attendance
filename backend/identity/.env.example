# Identity service — TCP microservice (auth + users)
NODE_ENV=development

# TCP transport this service listens on
TCP_HOST=0.0.0.0
TCP_PORT=4001

# Database (own schema: identity_db)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=dexa
DB_PASSWORD=dexa_password
DB_DATABASE=identity_db

# JWT — MUST be identical across all services + gateway
JWT_SECRET=super_secret_change_me
JWT_EXPIRES_IN=1d

# Where to reach the Employees service (deactivation check on login/validate)
EMPLOYEES_TCP_HOST=localhost
EMPLOYEES_TCP_PORT=4002

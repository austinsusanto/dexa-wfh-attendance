# ===========================================================================
# Backend environment. Copy to .env and adjust:  cp .env.example .env
# ===========================================================================

# App
NODE_ENV=development
PORT=3000
# Frontend origin allowed by CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# Database (matches root docker-compose.yml MySQL 8)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=dexa
DB_PASSWORD=dexa_password
DB_DATABASE=dexa_wfh

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=1d

# Uploads (attendance photos)
UPLOAD_DIR=uploads

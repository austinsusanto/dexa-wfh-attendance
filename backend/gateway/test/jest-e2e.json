{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": ".",
	"testEnvironment": "node",
	"testRegex": ".e2e-spec.ts$",
	"transform": {
		"^.+\\.(t|j)s$": "ts-jest"
	},
	"moduleNameMapper": {
		"^@dexa/common/(.*)$": "<rootDir>/../../common/dist/$1",
		"^@dexa/common$": "<rootDir>/../../common/dist"
	}
}

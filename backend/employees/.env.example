# Employees service — TCP microservice (master data karyawan)
NODE_ENV=development

# TCP transport this service listens on
TCP_HOST=0.0.0.0
TCP_PORT=4002

# Database (own schema: employees_db)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=dexa
DB_PASSWORD=dexa_password
DB_DATABASE=employees_db

# Where to reach the Identity service (provision login account on create)
IDENTITY_TCP_HOST=localhost
IDENTITY_TCP_PORT=4001

# =============================================================================
# Production environment for docker-compose.prod.yml.
# Copy to `.env.prod` on the server and fill in real secrets. NEVER commit it.
#
#   cp .env.prod.example .env.prod
#   # edit .env.prod, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# =============================================================================

# --- Public domain (Caddy auto-HTTPS) ---------------------------------------
# Your DuckDNS subdomain (or own domain) pointing at the VM's public IP.
DOMAIN=dexa-wfh.duckdns.org

# Frontend build-time config. For the single-origin Caddy setup leave these
# relative; the SPA then calls /api/v1 and loads photos from /uploads/* on the
# same origin. Override only if you split the frontend to a different host.
VITE_API_BASE_URL=/api/v1
VITE_API_ORIGIN=

# --- Shared secret -----------------------------------------------------------
# MUST be identical for gateway + identity. CHANGE THIS to a long random string.
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# --- MySQL -------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_USER=dexa
MYSQL_PASSWORD=change_me_dexa
# The init script creates identity_db / employees_db / attendances_db.
MYSQL_DATABASE=identity_db

# --- MinIO (object storage for attendance photos) ----------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=attendance-photos